{
	"name": "n8n-nodes-poe",
	"version": "1.0.1",
	"publishConfig": {
		"access": "public"
	},
	"description": "n8n community node for Poe — send prompts to AI models via Poe API.",
	"license": "MIT",
	"homepage": "https://github.com/ayat-med/n8n-nodes-poe",
	"keywords": [
		"n8n-community-node",
		"n8n-community-node-package",
		"n8n-nodes-poe",
		"n8n",
		"n8n-nodes",
		"poe",
		"ai",
		"llm",
		"automation"
	],
	"author": {
		"name": "Your Name",
		"email": "your.email@example.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ayat-med/n8n-nodes-poe.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": false,
		"credentials": [
			"dist/credentials/PoeApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Poe/Poe.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.1",
		"release-it": "19.2.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
